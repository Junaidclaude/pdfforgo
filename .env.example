# ─────────────────────────────────────────────
# Site Configuration
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Google AdSense
# ─────────────────────────────────────────────
# Publisher ID from your AdSense account (ca-pub-XXXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXXX

# Individual ad slot IDs from your AdSense ad units
NEXT_PUBLIC_ADSENSE_SLOT_HEADER=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_PRE_DOWNLOAD=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=XXXXXXXXXX

# ─────────────────────────────────────────────
# CloudConvert API (for Word↔PDF conversion)
# Get your free API key at https://cloudconvert.com/register
# Free tier: 25 conversions/day
# ─────────────────────────────────────────────
CLOUDCONVERT_API_KEY=your_cloudconvert_api_key

# ─────────────────────────────────────────────
# Cloudflare R2 Storage (optional)
# Only needed if you enable server-side file processing
# ─────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=pdfforge-uploads
# Public R2 bucket URL (if public access is enabled)
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev

# ─────────────────────────────────────────────
# Analytics (optional)
# ─────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────
# App Environment
# ─────────────────────────────────────────────
NODE_ENV=development
