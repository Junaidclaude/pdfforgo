# ─────────────────────────────────────────────
# Site Configuration
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Google AdSense
# ─────────────────────────────────────────────
# Publisher ID from your AdSense account (ca-pub-XXXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXXX

# Individual ad slot IDs from your AdSense ad units
NEXT_PUBLIC_ADSENSE_SLOT_HEADER=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_PRE_DOWNLOAD=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=XXXXXXXXXX

# ─────────────────────────────────────────────
# CloudConvert API (for Word↔PDF conversion)
# Get your free API key at https://cloudconvert.com/register
# Free tier: 25 conversions/day
# ─────────────────────────────────────────────
CLOUDCONVERT_API_KEY=your_cloudconvert_api_key

# ─────────────────────────────────────────────
# Cloudflare R2 Storage (optional)
# Only needed if you enable server-side file processing
# ─────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=pdfforge-uploads
# Public R2 bucket URL (if public access is enabled)
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev

# ─────────────────────────────────────────────
# Analytics (optional)
# ─────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────
# Clerk Authentication
# Get keys at https://clerk.com → your app → API Keys
# ─────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─────────────────────────────────────────────
# Stripe
# Get keys at https://dashboard.stripe.com → Developers → API keys
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Create two recurring prices in Stripe Dashboard, paste IDs here
STRIPE_PRICE_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_ANNUAL=price_XXXXXXXXXXXXXXXXXXXXXXXX
# Webhook secret from Stripe CLI or Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────
# App Environment
# ─────────────────────────────────────────────
NODE_ENV=development
